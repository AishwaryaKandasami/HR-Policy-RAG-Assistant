# HR Policy Q&A Bot — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Required ───────────────────────────────────────────────────────

# OpenAI API key — used to embed documents at ingestion time.
# Also used to pre-load demo docs at backend startup.
OPENAI_API_KEY=sk-...

# ── Optional (LLM generation — Phase 2) ───────────────────────────

# Groq API key — for Llama 3.1 8B / Llama 3.3 70B generation.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google API key — for Gemini Flash 2.0 generation.
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AI...

# Note: Users can also supply their own API keys at query time
# via the frontend LLM selector — no server-side key required.
