# ──────────────────────────────────────────────────────
# .env.example — Environment variable template
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your real API keys.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────

# OpenAI API key — used by ingest.py and retriever.py
# to generate embeddings via text-embedding-3-small.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq API key — used by generator.py to call
# Llama 3.1 8B for answer generation.
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY= 